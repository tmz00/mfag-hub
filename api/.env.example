APP_NAME=MFAGHubAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Local Docker defaults only. Override these in your untracked .env.
MYSQL_ROOT_PASSWORD=local_root_password

# `stack` defaults to `single` in local/testing and `daily` elsewhere.
# Set LOG_STACK to override the underlying channel explicitly.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=mfag_hub
DB_USERNAME=mfag_user
DB_PASSWORD=local_db_password
BACKUP_RETENTION_COUNT=14
BACKUP_SCHEDULE_TIME=02:15

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=file
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_PATTERNS=

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@mfag.local
MAIL_FROM_NAME="MFAG Hub"

HANDBOOK_STORAGE_DISK=local
HANDBOOK_STORAGE_PREFIX=handbook

WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:dev@mfag.local
