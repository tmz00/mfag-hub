{
  "name": "mfag-hub/laravel-api",
  "type": "project",
  "description": "MFAG Hub backend API (Laravel + MySQL)",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.3",
    "minishlink/web-push": "^9.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.18",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.0",
    "phpunit/phpunit": "^11.0",
    "laravel/pail": "^1.2",
    "laravel/tinker": "^2.11"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"@unlink(__DIR__.'/bootstrap/cache/packages.php'); @unlink(__DIR__.'/bootstrap/cache/services.php');\"",
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "test:snapshot-scripts": [
      "bash scripts/tests/test-snapshot-scripts.sh"
    ],
    "test": [
      "@php artisan test",
      "@test:snapshot-scripts"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
